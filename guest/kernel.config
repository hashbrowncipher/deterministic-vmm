# base: tinyconfig
# standalone: true
#
# Deterministic microVM kernel — minimal kernel for the deterministic VMM.
# Boots with a single vCPU, no ACPI, no PCI, no networking. The VMM loads bzImage directly
# (no EFI/bootloader), provides serial console via emulated 16550 UART, and controls rdrand/
# rdtsc/cpuid exits for fully deterministic execution.
#
# "base: tinyconfig" starts from the smallest possible x86 config.
# "standalone: true" skips the shared config.fragment — this fragment is self-contained.

# =============================================================================
# Core: 64-bit x86, single CPU, no KASLR, no EFI
# =============================================================================
CONFIG_64BIT=y
CONFIG_X86_64=y

# Single vCPU — no SMP overhead, no scheduler complexity
# CONFIG_SMP is not set

# No KASLR — simplifies debugging, and our deterministic rdrand would make it
# deterministic anyway
# CONFIG_RANDOMIZE_BASE is not set

# Enable Intel CPU support so the kernel recognizes the "GenuineIntel" CPUID
# vendor string via native_calibrate_tsc(). This lets it read CPUID leaf 0x15
# (TSC/crystal frequency) and pre-set lapic_timer_period, skipping the APIC
# timer calibration loop (which is extremely slow under RDTSC interception).
CONFIG_PROCESSOR_SELECT=y
CONFIG_CPU_SUP_INTEL=y
# CONFIG_CPU_SUP_AMD is not set
# CONFIG_CPU_SUP_HYGON is not set
# CONFIG_CPU_SUP_CENTAUR is not set
# CONFIG_CPU_SUP_ZHAOXIN is not set

# No EFI — the VMM loads bzImage directly into guest memory
# CONFIG_EFI is not set

# tinyconfig disables these; re-enable since many subsystems depend on them
# (TMPFS needs SHMEM, various things need MULTIUSER)
CONFIG_MULTIUSER=y
CONFIG_SHMEM=y

# =============================================================================
# Console: virtio-console (hvc0) is the only output path
# =============================================================================
CONFIG_TTY=y
# CONFIG_SERIAL_8250 is not set
CONFIG_PRINTK=y
# No virtual terminal — virtio-console is the only output path
# CONFIG_VT is not set

# Virtio console over MMIO transport — batches output into virtqueue buffers,
# reducing VMEXITs from one-per-byte (serial) to one-per-write.
CONFIG_VIRTIO_MENU=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_MMIO_CMDLINE_DEVICES=y
CONFIG_VIRTIO_CONSOLE=y

# Rootfs is a cpio initramfs unpacked by the kernel into rootfs (tmpfs).
# No block device, no on-disk filesystem driver needed.

# =============================================================================
# Initramfs and userspace execution
# =============================================================================
# BLK_DEV_INITRD makes the kernel honor the boot-protocol ramdisk_image /
# ramdisk_size fields — that's how the VMM hands us the cpio.
CONFIG_BLK_DEV_INITRD=y
CONFIG_BINFMT_ELF=y

# =============================================================================
# Pseudo-filesystems: needed by /init and basic userspace
# =============================================================================
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# =============================================================================
# Explicitly disabled: documenting rationale for anything someone might expect
# =============================================================================

# No modules — everything is built-in. The guest lifetime is a single build
# job; there's nothing to load dynamically.
# CONFIG_MODULES is not set

# No networking — the guest communicates with the host via VMCALL, not sockets
# CONFIG_NET is not set

# No PCI — the VMM provides no PCI bus; all devices are port-mapped
# CONFIG_PCI is not set

# No ACPI — the VMM provides no ACPI tables. Hardware topology is trivial
# (1 CPU, fixed memory, UART).
# CONFIG_ACPI is not set

# No graphics — serial console only
# CONFIG_DRM is not set
# CONFIG_FB is not set
# CONFIG_VGA_CONSOLE is not set

# No USB — no USB controller in the VMM
# CONFIG_USB_SUPPORT is not set

# No sound
# CONFIG_SOUND is not set

# No input devices — serial only
# CONFIG_INPUT is not set
# CONFIG_SERIO is not set
# CONFIG_HID is not set

# No power management — the VMM controls execution directly
# CONFIG_SUSPEND is not set
# CONFIG_HIBERNATION is not set
# CONFIG_CPU_FREQ is not set

# No NUMA, memory hotplug, huge pages — single contiguous memory region
# CONFIG_NUMA is not set
# CONFIG_MEMORY_HOTPLUG is not set
# CONFIG_HUGETLBFS is not set
# CONFIG_TRANSPARENT_HUGEPAGE is not set

# No debugging/tracing infrastructure — keep the image small
# CONFIG_FTRACE is not set
# CONFIG_PROFILING is not set
# CONFIG_KPROBES is not set

# No KVM or virtualization — no nesting
# CONFIG_VIRTUALIZATION is not set

# No IMA/EVM — integrity is guaranteed by the VMM's deterministic execution
# CONFIG_IMA is not set
# CONFIG_EVM is not set

# No BPF — no tracing or filtering needed
# CONFIG_BPF_SYSCALL is not set

# No IOMMU — no PCI, no DMA, no need
# CONFIG_IOMMU_SUPPORT is not set

# No LSMs — single-purpose VM, no multi-user security boundary
# CONFIG_SECURITY is not set

# No I/O schedulers — no block devices beyond initramfs
# CONFIG_MQ_IOSCHED_DEADLINE is not set
# CONFIG_MQ_IOSCHED_KYBER is not set
# CONFIG_IOSCHED_BFQ is not set

# No RTC — the VMM provides no CMOS RTC hardware
# CONFIG_RTC_CLASS is not set

# No CPU vulnerability mitigations — deterministic virtual CPU has no speculative
# execution side channels. Skips all the Spectre/Meltdown/etc. probing at boot.
# (Newer kernels renamed SPECULATION_MITIGATIONS → CPU_MITIGATIONS; turning off
# the menuconfig disables MITIGATION_RETPOLINE / MITIGATION_RETHUNK transitively,
# both of which would otherwise pull in objtool.)
# CONFIG_CPU_MITIGATIONS is not set

# Disable Intel CET indirect branch tracking. It's def_bool y on x86_64 with a
# capable compiler, and `select OBJTOOL`s — which would require host libelf.
# CONFIG_X86_KERNEL_IBT is not set

# No GCC plugins — randstruct in particular randomizes struct layouts per build
# unless seeded, which is hostile to byte-reproducible builds.
# CONFIG_GCC_PLUGINS is not set



# =============================================================================
# Tickless idle + low HZ — stop ticks when idle, and reduce tick rate during
# active periods. NO_HZ_FULL would be ideal (stop ticks even during userspace)
# but the boot CPU is prohibited from adaptive-ticks mode, and we only have one
# vCPU. HZ=100 keeps the timer overhead low during active phases.
# =============================================================================
CONFIG_NO_HZ_IDLE=y
# CONFIG_HZ_PERIODIC is not set
CONFIG_HZ_100=y
CONFIG_HZ=100

# =============================================================================
# Stack traces — needed for NMI-triggered kernel panics to show useful output
# =============================================================================
CONFIG_STACKTRACE=y
CONFIG_UNWINDER_FRAME_POINTER=y
CONFIG_KALLSYMS=y
CONFIG_BUG=y
CONFIG_DEBUG_BUGVERBOSE=y

# =============================================================================
# Size optimizations
# =============================================================================
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
CONFIG_KERNEL_XZ=y
CONFIG_SLUB=y
CONFIG_SLUB_TINY=y
